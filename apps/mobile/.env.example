# =============================================================
# PREDIAL360 Mobile — Variáveis de ambiente Expo
# Copie para .env.local — NUNCA commitar com valores reais
# =============================================================

# URL da API (sem barra final)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Deeplink scheme (ex: predial360://)
EXPO_PUBLIC_APP_SCHEME=predial360

# Sentry (opcional)
EXPO_PUBLIC_SENTRY_DSN=
