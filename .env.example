# =============================================================
# PREDIAL360 — Variáveis de ambiente (copie para .env)
# NUNCA commitar o .env real — apenas este .example
# =============================================================

# ── Aplicação ─────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ── Banco de dados ─────────────────────────────────────────────
DATABASE_URL=postgresql://predial360:predial360@localhost:5432/predial360_dev
DATABASE_TEST_URL=postgresql://predial360:predial360@localhost:5432/predial360_test

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=TROQUE_POR_SEGREDO_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=TROQUE_POR_SEGREDO_REFRESH_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ── 2FA ────────────────────────────────────────────────────────
TOTP_APP_NAME=Predial360

# ── Anthropic (Claude API) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-TROQUE_PELA_CHAVE_REAL
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=TROQUE
AWS_SECRET_ACCESS_KEY=TROQUE
AWS_S3_BUCKET=predial360-dev
AWS_IOT_ENDPOINT=TROQUE.iot.us-east-1.amazonaws.com

# LocalStack (dev)
AWS_ENDPOINT_URL=http://localhost:4566

# CDN (CloudFront em produção — opcional)
AWS_CDN_BASE_URL=

# ── Firebase ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=predial360-dev
FIREBASE_CLIENT_EMAIL=TROQUE
FIREBASE_PRIVATE_KEY=TROQUE

# ── Google Maps ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=TROQUE
GOOGLE_OAUTH_CLIENT_ID=TROQUE
GOOGLE_OAUTH_CLIENT_SECRET=TROQUE

# ── Apple Sign In ──────────────────────────────────────────────
APPLE_OAUTH_CLIENT_ID=TROQUE
APPLE_OAUTH_KEY_ID=TROQUE
APPLE_OAUTH_TEAM_ID=TROQUE
APPLE_OAUTH_PRIVATE_KEY=TROQUE

# ── Asaas (pagamentos) ─────────────────────────────────────────
ASAAS_API_KEY=TROQUE
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=TROQUE

# ── Sentry ─────────────────────────────────────────────────────
SENTRY_DSN=TROQUE

# ── Criptografia (AES-256) ─────────────────────────────────────
ENCRYPTION_KEY=TROQUE_POR_CHAVE_HEX_32_BYTES_64_CHARS
